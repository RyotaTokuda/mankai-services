# ─────────────────────────────────────────────────────────────────────────────
# このファイルはテンプレートです。.env.local を作成して値を入れてください。
# .env.local は .gitignore に含まれており、コミットされません。
# ─────────────────────────────────────────────────────────────────────────────
#
# 各 apps/ には個別の .env.local.example があります:
#   apps/file-converter/.env.local.example  ← ユーザー向けアプリ
#   apps/api/.env.local.example             ← Webhook サーバー
#
# ─────────────────────────────────────────────────────────────────────────────
# Supabase（全アプリ共通・1プロジェクト共有）
# Supabase Dashboard → Settings → API から取得
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ⚠️  Service Role Key — apps/api のみ使用。NEXT_PUBLIC_ は絶対につけない
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─────────────────────────────────────────────────────────────────────────────
# Lemon Squeezy
# ─────────────────────────────────────────────────────────────────────────────

# ストアスラッグ（LS Dashboard の URL から確認: app.lemonsqueezy.com/[slug]）
NEXT_PUBLIC_LS_STORE_SLUG=mankai-software

# Pro プランの Variant ID（LS Dashboard → Products → Variants で確認）
NEXT_PUBLIC_LS_PRO_VARIANT_ID=123456

# ⚠️  Webhook Secret — apps/api のみ使用。NEXT_PUBLIC_ は絶対につけない
LEMON_SQUEEZY_WEBHOOK_SECRET=your-webhook-signing-secret

# ─────────────────────────────────────────────────────────────────────────────
# アプリ URL（チェックアウトのリダイレクト先検証に使用）
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# 本番: NEXT_PUBLIC_APP_URL=https://file-converter-beige.vercel.app
