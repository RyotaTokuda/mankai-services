# ─────────────────────────────────────────────────────────────────────────────
# Supabase（共有プロジェクト）
# Supabase Dashboard → Settings → API から取得
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─────────────────────────────────────────────────────────────────────────────
# Lemon Squeezy（課金）
# ─────────────────────────────────────────────────────────────────────────────
# ストアスラッグ（チェックアウト URL 生成に使用）
NEXT_PUBLIC_LS_STORE_SLUG=mankai

# Pro プランの Variant ID（Lemon Squeezy Dashboard → Products で確認）
NEXT_PUBLIC_LS_PRO_VARIANT_ID=your_variant_id_here

# アプリの公開 URL（チェックアウト後のリダイレクト検証に使用）
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# セットアップ手順
# ─────────────────────────────────────────────────────────────────────────────
#
# 1. .env.local.example を .env.local にコピー
#      cp .env.local.example .env.local
#
# 2. Supabase の値をルートの .env.local.example から取得して貼り付け
#
# 3. Lemon Squeezy のプラン Variant ID を設定
#    （課金機能を使わない場合は空のままで OK）
#
# 4. Vercel デプロイ時は Vercel の Environment Variables にも同じ値を設定
