# ─────────────────────────────────────────────────────────────────────────────
# Supabase（共有プロジェクト）
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# ⚠️  Service Role Key は RLS を完全にバイパスする最強権限キー
# ⚠️  絶対にクライアントサイドに渡さない。NEXT_PUBLIC_ は絶対につけない
# ⚠️  Vercel の Environment Variables に設定し、コードには書かない
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─────────────────────────────────────────────────────────────────────────────
# Lemon Squeezy
# ─────────────────────────────────────────────────────────────────────────────

# Webhook Secret（Lemon Squeezy Dashboard → Webhooks で設定したシークレット）
# ⚠️  サーバーサイドのみ。絶対に NEXT_PUBLIC_ をつけない
LEMON_SQUEEZY_WEBHOOK_SECRET=your-webhook-secret

# ─────────────────────────────────────────────────────────────────────────────
# Lemon Squeezy セットアップ手順
# ─────────────────────────────────────────────────────────────────────────────
#
# 1. https://app.lemonsqueezy.com でアカウント作成・ストア設定
#
# 2. Products → 各アプリのサブスクリプション商品を作成
#    Variant ID をメモ（NEXT_PUBLIC_LS_PRO_VARIANT_ID に使う）
#
# 3. Settings → Webhooks → Add webhook
#    URL: https://mankai-api.vercel.app/api/webhooks/lemon
#    Events（全部チェック）:
#      ✓ subscription_created
#      ✓ subscription_updated
#      ✓ subscription_cancelled
#      ✓ subscription_resumed
#      ✓ subscription_expired
#      ✓ subscription_paused
#      ✓ subscription_unpaused
#      ✓ subscription_payment_success
#      ✓ subscription_payment_failed
#    Signing Secret → 生成されたシークレットを LEMON_SQUEEZY_WEBHOOK_SECRET に設定
#
# 4. Vercel の mankai-api プロジェクトの Environment Variables に上記を設定
