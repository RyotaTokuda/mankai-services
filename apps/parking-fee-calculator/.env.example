# Google AI Studio API Key（Gemini 1.5 Flash 用）
# https://aistudio.google.com/app/apikey から取得（無料・クレカ不要）
GOOGLE_GENERATIVE_AI_API_KEY=your_google_ai_api_key_here

# Supabase（認証・履歴保存）
# https://supabase.com でプロジェクト作成後、Settings → API から取得
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# OCR kill switch（緊急時に "false" にすると全解析を即時停止できる）
# 未設定または "true" の場合は有効
# OCR_ENABLED=false
