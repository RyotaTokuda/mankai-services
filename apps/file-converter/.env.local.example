# ─────────────────────────────────────────────────────────────────────────────
# Supabase
# Supabase Dashboard → Settings → API から取得
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─────────────────────────────────────────────────────────────────────────────
# Stripe
# Stripe Dashboard → Products → Price ID を取得
# ─────────────────────────────────────────────────────────────────────────────

# Plus プラン Price ID（Stripe Dashboard で作成）
NEXT_PUBLIC_STRIPE_PLUS_MONTHLY_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PLUS_YEARLY_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx

# Stripe Secret Key（サーバーサイドのみ。Checkout Session / Portal 作成に使用）
# ⚠️  NEXT_PUBLIC_ を絶対につけない
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# アプリの公開 URL（Checkout の success_url / cancel_url に使用）
NEXT_PUBLIC_APP_URL=https://file-converter-beige.vercel.app

# ─────────────────────────────────────────────────────────────────────────────
# Supabase 初期セットアップ手順
# ─────────────────────────────────────────────────────────────────────────────
#
# 1. https://supabase.com でプロジェクト作成
#
# 2. Authentication → Providers → Google を有効化
#    a. Google Cloud Console (console.cloud.google.com) でプロジェクト作成
#    b. 「APIとサービス」→「認証情報」→「OAuth 2.0 クライアントID」を作成
#       アプリの種類: ウェブアプリケーション
#       承認済みリダイレクト URI:
#         https://<your-project-ref>.supabase.co/auth/v1/callback
#    c. Client ID / Client Secret を Supabase の Google Provider 設定に貼り付け
#
# 3. Authentication → Email → 設定確認
#    - Enable Email OTP: ON（デフォルト）
#    - OTP Expiry: 600秒（推奨）
#    - Rate Limiting: デフォルトのまま（60秒間隔）
#
# 4. Authentication → URL Configuration
#    Site URL:
#      https://file-converter-beige.vercel.app
#    Redirect URLs（改行区切りで両方追加）:
#      https://file-converter-beige.vercel.app/auth/callback
#      http://localhost:3000/auth/callback
#
# 5. Vercel の Environment Variables にも同様に設定
#    NEXT_PUBLIC_SUPABASE_URL
#    NEXT_PUBLIC_SUPABASE_ANON_KEY
#
# ─────────────────────────────────────────────────────────────────────────────
# Stripe セットアップ手順
# ─────────────────────────────────────────────────────────────────────────────
#
# 1. https://dashboard.stripe.com でアカウント作成
#
# 2. Products → Plus サブスクリプション商品を作成
#    - Monthly price → NEXT_PUBLIC_STRIPE_PLUS_MONTHLY_PRICE_ID
#    - Yearly price  → NEXT_PUBLIC_STRIPE_PLUS_YEARLY_PRICE_ID
#
# 3. Settings → Customer Portal → 有効化
#    - サブスクリプションのキャンセル・プラン変更を許可
#
# 4. Developers → API keys → Secret key を STRIPE_SECRET_KEY に設定
#
# 5. Vercel の file-converter プロジェクトの Environment Variables に設定
